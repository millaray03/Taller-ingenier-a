{
  "name": "Taller Ingenieria PHP & MySQL",
  "dockerComposeFile": "docker-compose.yml",
  "service": "db",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "bmewburn.vscode-intelephense-client"
      ]
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y php8.3-cli php8.3-mysql php8.3-common"
}